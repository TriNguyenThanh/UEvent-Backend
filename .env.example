# ==========================================
# UEvent Backend - Local Environment Example
# Copy this file to .env and replace placeholder values.
# Never commit real secrets, passwords, private keys, or service accounts.
# ==========================================

# ==========================================
# DJANGO CORE SETTINGS
# ==========================================
SECRET_KEY=change-me-local-django-secret
TICKET_QR_SECRET=change-me-local-ticket-secret
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# Set USE_SQLITE=True only for very small local smoke tests.
USE_SQLITE=False

# ==========================================
# DATABASE SETTINGS (POSTGRESQL)
# Docker Compose: HOST=db, PORT=5432
# Bare-metal local: HOST=localhost, PORT=5432
# ==========================================
POSTGRES_DB=uevent_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
HOST=db
PORT=5432

# ==========================================
# REDIS, CACHE & CELERY
# Docker Compose: redis://redis:6379/*
# Bare-metal local: redis://localhost:6379/*
# ==========================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=True
CELERY_TASK_TIME_LIMIT=300

# ==========================================
# KEYCLOAK / OIDC
# Replace these values with your Keycloak realm and clients.
# ==========================================
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=uevent
KEYCLOAK_AUDIENCE=uevent-mobile
KEYCLOAK_CLIENT_ID=uevent-mobile
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SCOPE=openid email profile offline_access
KEYCLOAK_JWKS_CACHE_TTL=300
KEYCLOAK_JWKS_TIMEOUT=5
KEYCLOAK_TOKEN_TIMEOUT=10
KEYCLOAK_JWT_ALGORITHMS=RS256

# Keycloak Admin API, used by OTP email login / token exchange.
KEYCLOAK_ADMIN_CLIENT_ID=uevent-backend
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-keycloak-admin-client-secret

# ==========================================
# PASSKEY / WEBAUTHN
# ==========================================
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=UEvent
PASSKEY_EXPECTED_ORIGINS=http://localhost,http://localhost:3000,http://127.0.0.1:3000
PASSKEY_CHALLENGE_TTL_SECONDS=300

# ==========================================
# GOOGLE OAUTH
# Comma-separated OAuth client IDs accepted by backend.
# Use the same Web Client ID configured in the Flutter app.
# ==========================================
GOOGLE_OAUTH_CLIENT_IDS=

# ==========================================
# EMAIL / OTP
# For local testing, you may switch EMAIL_BACKEND to console backend.
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=UEvent <noreply@uevent.local>
OTP_TTL_SECONDS=180
OTP_MAX_ATTEMPTS=5
OTP_COOLDOWN_SECONDS=60

# ==========================================
# FIREBASE CLOUD MESSAGING (FCM)
# Docker Compose mounts ./firebase-service-account.json to /run/firebase-service-account.json.
# Keep FCM_ENABLED=false until a real service account is configured.
# ==========================================
FCM_ENABLED=false
FCM_DRY_RUN=false
FIREBASE_CREDENTIALS_PATH=/run/firebase-service-account.json
FIREBASE_CREDENTIALS_JSON=
FCM_BATCH_SIZE=500
FCM_MAX_RETRIES=3
FCM_DEVICE_TOKEN_TTL_DAYS=365

# ==========================================
# PUBLIC URLS
# ==========================================
PUBLIC_WEB_BASE_URL=http://localhost:3000

# ==========================================
# AWS S3 / OBJECT STORAGE (OPTIONAL)
# Leave blank for local development unless uploads need object storage.
# ==========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_CACHE_CONTROL=max-age=86400
AWS_S3_PRESIGNED_URL_EXPIRES=3600

# ==========================================
# OBSERVABILITY (OPTIONAL)
# ==========================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=uevent-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
OPENOBSERVE_URL=http://localhost:5080
OPENOBSERVE_ORGANIZATION=default
OPENOBSERVE_AUDIT_STREAM=uevent_audit
OPENOBSERVE_USERNAME=
OPENOBSERVE_PASSWORD=
OPENOBSERVE_TIMEOUT_SECONDS=5
